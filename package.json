{
  "name": "test-containers-demo",
  "version": "1.0.0",
  "description": "API Node.js + Postgres con pruebas de integración usando Testcontainers",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "npm run test:test-containers",
    "test:test-containers": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --config tests/test-containers/jest.test-containers.config.js --runInBand --reporters=default --reporters=jest-junit",
    "test:docker-compose": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --config tests/docker-compose/jest.docker-compose.config.js --runInBand --reporters=default --reporters=jest-junit",
    "test:no-containers": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --config tests/no-containers/jest.no-containers.config.js --runInBand --reporters=default --reporters=jest-junit",
    "test:mock": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --config tests/mock/jest.mocks.config.js --runInBand --reporters=default --reporters=jest-junit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.11.0",
    "cross-env": "^10.0.0",
    "fast-xml-parser": "^5.2.5",
    "jest": "^30.2.0",
    "jest-junit": "^16.0.0",
    "nodemon": "^3.1.10",
    "supertest": "^7.1.4",
    "testcontainers": "^11.6.0"
  },
  "jest": {
    "testEnvironment": "node"
  },
  "jest-junit": {
    "outputDirectory": "./test-results",
    "outputName": "junit.xml",
    "classNameTemplate": "{classname}",
    "titleTemplate": "{title}",
    "ancestorSeparator": " › ",
    "usePathForSuiteName": true,
    "suiteNameTemplate": "{filepath}"
  }
}
