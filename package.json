{
  "name": "test-containers-demo",
  "version": "1.0.0",
  "description": "API Node.js + Postgres con pruebas de integración usando Testcontainers",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "npm run test:test-containers",
    "test:test-containers": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --runInBand --reporters=default --reporters=jest-junit",
    "test:legacy:docker-compose": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --config jest.docker-compose.config.js --runInBand --reporters=default --reporters=jest-junit",
    "test:legacy:no-containers": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --config jest.no-containers.config.js --runInBand --reporters=default --reporters=jest-junit",
    "test:mock": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --config jest.mocks.config.js --runInBand --reporters=default --reporters=jest-junit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.6.0",
    "cross-env": "^10.0.0",
    "jest": "^30.1.3",
    "jest-junit": "^16.0.0",
    "nodemon": "^3.1.10",
    "supertest": "^7.1.4",
    "testcontainers": "^11.6.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests-test-containers/*.test-containers.int.test.js"
    ]
  },
  "jest-junit": {
    "outputDirectory": "./test-results",
    "outputName": "junit.xml",
    "classNameTemplate": "{classname}",
    "titleTemplate": "{title}",
    "ancestorSeparator": " › ",
    "usePathForSuiteName": true
  }
}
